# ==========================================================================
# Plansync Agent Backend — Environment Variables
# ==========================================================================
# HOW TO USE:
#   1. Copy this file:       cp .env.example .env
#   2. Open .env in your editor (VSCode / Cursor / nano / etc.)
#   3. Fill in the real values below
#   4. Save. NEVER commit .env — it's in .gitignore
#
# For PRODUCTION (Railway): set the same variables in the Railway dashboard
# at Project → Variables tab, OR via CLI: railway variables set KEY=value
# ==========================================================================


# --- Anthropic (required) -------------------------------------------------
# Get yours at: https://console.anthropic.com/settings/keys
# Click "Create Key", name it "plansync-dev", copy the key (shown only once)
ANTHROPIC_API_KEY=sk-ant-api03-REPLACE_ME


# --- Upstash Redis (required) ---------------------------------------------
# You said this is already set up. Go to: https://console.upstash.com/redis
# Click your database → "REST API" section → copy the two values below
UPSTASH_REDIS_REST_URL=https://REPLACE-ME.upstash.io
UPSTASH_REDIS_REST_TOKEN=REPLACE_ME


# --- Encryption key (required) --------------------------------------------
# Used to encrypt the Rocketlane API key at rest in Redis (AES-GCM).
# Generate your own by running this in your terminal:
#   openssl rand -base64 32
# Then paste the output here (it will be 44 characters ending in =)
ENCRYPTION_KEY=REPLACE_ME_WITH_openssl_rand_base64_32_OUTPUT


# --- CORS (required for prod, optional for local) -------------------------
# Comma-separated list of allowed origins for the frontend to call /agent
# Local: http://localhost:3000
# Prod:  https://plansync.vercel.app,https://*.rocketlane.com
ALLOWED_ORIGIN=http://localhost:3000


# --- Port (optional) ------------------------------------------------------
# Local dev port. Railway assigns its own PORT var automatically in prod.
PORT=3001


# --- Rocketlane API key for LOCAL TESTING ONLY ----------------------------
# NOT used in production — in production, users supply their own RL key
# via the ApiKeyCard in the UI (encrypted per session).
# Only used by agent/scripts/test-rl.ts during Hour 1–2 API verification.
# Get yours at: https://inbarajb.rocketlane.com → Settings → API keys
TEST_ROCKETLANE_API_KEY=REPLACE_ME_ONLY_FOR_TEST_SCRIPT
