# ==========================================================================
# Plansync Frontend — Environment Variables
# ==========================================================================
# HOW TO USE:
#   1. Copy this file:       cp .env.example .env.local
#   2. Open .env.local in your editor
#   3. Fill in the values below
#   4. Save. NEVER commit .env.local — it's in .gitignore
#
# For PRODUCTION (Vercel): set the same variables in the Vercel dashboard
# at Project → Settings → Environment Variables, OR via CLI: vercel env add
#
# Note: variables prefixed with NEXT_PUBLIC_ are exposed to the browser.
# Only put non-secret values here. Actual secrets (Anthropic key, Upstash
# token, encryption key) live on the BACKEND only (agent/.env).
# ==========================================================================


# --- Agent backend URL (required) -----------------------------------------
# Local dev: http://localhost:3001 (matches agent/.env PORT)
# Prod:      https://YOUR-RAILWAY-APP.up.railway.app
# We'll fill in the real Railway URL after the first deploy (Hour 0–1)
NEXT_PUBLIC_AGENT_URL=http://localhost:3001
